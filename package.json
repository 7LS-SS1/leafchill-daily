{
  "name": "leaf-chill-daily",
  "version": "1.0.0",
  "private": true,
  "description": "Thai restaurant staff, attendance, and wage management web app.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "prisma migrate deploy && next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed-safe.js",
    "legacy:start": "node src/server.js",
    "legacy:dev": "node src/server.js",
    "legacy:seed": "node src/seed.js",
    "legacy:start:test": "node src/server-test.js",
    "legacy:seed:test": "node src/seed-test.js",
    "check": "node --check src/server.js && node --check src/server-test.js && node --check src/store.js && node --check src/auth.js && node --check src/payroll.js && node --check src/seed.js && node --check src/seed-test.js && node --check public/app.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "next": "^14.2.23",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "prisma": "^5.22.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.23",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "node prisma/seed-safe.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "restaurant",
    "attendance",
    "payroll",
    "thai"
  ],
  "license": "MIT"
}
